#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: $0 OWNER/REPO" >&2
    exit 1
fi

repo=$1

cutoff="$(date -u -d '14 days ago' '+%Y-%m-%dT%H:%M:%SZ')"
export cutoff

gh release list -R "${repo}" --exclude-drafts --exclude-pre-releases --limit 200 --json tagName,publishedAt \
    | jq -er 'map(select(.publishedAt <= env.cutoff)) | sort_by(.publishedAt) | .[].tagName'
